#!/usr/bin/env bash
# wzsh 主管理命令
# 整合 wzsh、wzsh-install、z 的功能

WZSH_HOME="${WZSH_HOME:-${HOME}/.zsh}"
WZSH_BIN="${WZSH_BIN:-${HOME}/.local/share/wzsh/bin}"

# 加载日志函数（从 basic.zsh 提取的 bash 兼容版本）
_log() { echo "[$(date '+%F %T')] [$1] $2"; }
zinfo()  { _log "INFO"  "$*"; }
zwarn()  { _log "WARN"  "$*"; }
zerror() { _log "ERROR" "$*"; }

_zlink() {
    # 软链文件
    local src=$1 dest=$2
    if [ -L "$dest" ]; then
        if [ "$(readlink "$dest")" = "$src" ]; then
            zinfo "✓ 已正确链接: $dest"
        else
            zinfo "重新链接: $dest -> $src"
            ln -sf "$src" "$dest"
        fi
    elif [ -e "$dest" ]; then
        local bak="${dest}.bak.$(date +%Y%m%d%H%M%S)"
        zinfo "备份: $dest -> $bak"
        mv "$dest" "$bak"
        zinfo "链接: $dest -> $src"
        ln -sf "$src" "$dest"
    else
        zinfo "链接: $dest -> $src"
        ln -sf "$src" "$dest"
    fi
}

# =============================================================================
# 顶层命令
# =============================================================================

update() {
    # 更新 wzsh
    cd ~/.zsh && proxyon
    git pull && git submodule update --init --recursive
    proxyoff && cd - && zsh
}

conf() {
    # 打开配置文件
    cd "${WZSH_HOME}" && eval "${EDITOR}"; cd -
}

# =============================================================================
# plugin 子命令
# =============================================================================

__get_plugin_dir() {
    # 获取插件目录（优先从 config.py 查，回退到旧逻辑）
    local name=$1
    local path
    path=$(/usr/bin/python3 "${WZSH_HOME}/lib/pythonx/config.py" path-of "$name" 2>/dev/null)
    if [ -n "$path" ]; then
        echo "$path"
    else
        echo "${WZSH_HOME}/plugins/wzsh-${name}"
    fi
}

__create_plugin() {
    # 创建插件骨架
    local name=$1
    if [ -z "$name" ]; then
        zerror "缺少参数 {name}"
        return 1
    fi
    local plugin_root="${2:-${WZSH_HOME}/plugins}"
    local dirname="${plugin_root}/wzsh-${name}"
    zinfo "wzsh-${name} 开始创建"
    mkdir -p "$dirname/bin" "$dirname/config"
    echo '{}' > "$dirname/config/help.json"
    for _name in aliases.zsh zprofile zshenv zshrc installer; do
        touch "$dirname/$_name"
        zinfo "创建 $dirname/$_name"
    done
    echo ". \${WZSH_HOME}/plugins/wzsh-${name}/aliases.zsh" >> "$dirname/zshrc"
    chmod +x "$dirname/installer"
    zinfo "wzsh-${name} 创建成功"
}

__conf_plugin() {
    # 编辑插件
    local dirname
    dirname=$(__get_plugin_dir "$1")
    if [ ! -d "$dirname" ]; then
        zwarn "插件 $1 不存在"
        return 1
    fi
    cd "$dirname" && eval "${EDITOR}"; cd -
}

__home_plugin() {
    # 输出插件目录
    __get_plugin_dir "$1"
}

__init_plugin() {
    # 执行插件 init.zsh
    local init_path
    init_path="$(__get_plugin_dir "$1")/init.zsh"
    if [ ! -f "$init_path" ]; then
        zerror "缺少脚本 ${init_path}"
        return 1
    fi
    bash "$init_path"
}

__add_brew() {
    # 将软件添加到插件的 Brewfile
    local plugin_home
    plugin_home=$(__get_plugin_dir "$1")
    if [ ! -d "$plugin_home" ]; then
        zerror "插件 $1 不存在"
        return 1
    fi
    brew bundle --file="${plugin_home}/Brewfile" add "${@:2}"
}

__remove_brew() {
    # 从插件 Brewfile 移除软件
    local plugin_home
    plugin_home=$(__get_plugin_dir "$1")
    if [ ! -d "$plugin_home" ]; then
        zerror "插件 $1 不存在"
        return 1
    fi
    brew bundle --file="${plugin_home}/Brewfile" remove "${@:2}"
}

__install_one() {
    # 安装单个插件
    # 参数：$1=plugin_home $2=no_brew
    local plugin_home=$1
    local no_brew=$2

    if [ ! -d "$plugin_home" ]; then
        zwarn "插件目录不存在: $plugin_home"
        return 1
    fi

    zinfo "安装插件: $plugin_home"

    # 软链 bin/ 下可执行文件到 WZSH_BIN
    local plugin_bin_dir="${plugin_home}/bin"
    if [ -d "$plugin_bin_dir" ]; then
        zinfo "软链脚本命令: ${plugin_bin_dir} → ${WZSH_BIN}"
        mkdir -p "$WZSH_BIN"
        while IFS= read -r bin_file; do
            if [ -x "$bin_file" ]; then
                local dest_file="${WZSH_BIN}/$(basename "$bin_file")"
                _zlink "$bin_file" "$dest_file"
            fi
        done < <(find "$plugin_bin_dir" -maxdepth 1 -type f)
    fi

    # 执行 Brewfile
    local brewfile="${plugin_home}/Brewfile"
    if [ -f "$brewfile" ] && [ "$no_brew" != "true" ]; then
        zinfo "安装 Brew 软件: ${brewfile}"
        wbrew bundle install --file="$brewfile"
    fi

    # 执行自定义安装脚本
    local installer="${plugin_home}/installer"
    if [ -f "$installer" ]; then
        zinfo "执行安装脚本: ${installer}"
        bash "$installer"
    fi

    zinfo "插件安装完成: $plugin_home"
}

__install_plugin() {
    # 安装插件，支持按 name 单装或全装
    # 用法：__install_plugin [name] [--no-brew]
    local no_brew=false
    local target_name=""
    for arg in "$@"; do
        case $arg in
            --no-brew) no_brew=true ;;
            *) target_name=$arg ;;
        esac
    done

    # 确保 config.local.json 存在
    local local_config="${WZSH_HOME}/config.local.json"
    if [ ! -f "$local_config" ]; then
        zinfo "创建 config.local.json"
        echo '{ "plugins": [] }' > "$local_config"
    fi

    if [ -n "$target_name" ]; then
        # 安装指定插件
        local plugin_home
        plugin_home=$(__get_plugin_dir "$target_name")
        # github 插件：目录不存在则先 clone
        local github_url
        github_url=$(/usr/bin/python3 "${WZSH_HOME}/lib/pythonx/config.py" github-of "$target_name" 2>/dev/null)
        if [ -n "$github_url" ] && [ ! -d "$plugin_home" ]; then
            zinfo "克隆插件: https://github.com/${github_url} -> ${plugin_home}"
            git clone "https://github.com/${github_url}" "$plugin_home"
        fi
        __install_one "$plugin_home" "$no_brew"
    else
        # 安装全部插件，先处理 github clone
        while IFS='|' read -r path url; do
            if [ -n "$url" ] && [ ! -d "$path" ]; then
                zinfo "克隆插件: https://github.com/${url} -> ${path}"
                git clone "https://github.com/${url}" "$path"
            fi
        done < <(/usr/bin/python3 "${WZSH_HOME}/lib/pythonx/config.py" github-list 2>/dev/null)

        while IFS= read -r plugin_home; do
            __install_one "$plugin_home" "$no_brew"
        done < <(/usr/bin/python3 "${WZSH_HOME}/lib/pythonx/config.py" paths 2>/dev/null)
    fi
}

plugin() {
    # 插件管理子命令
    local action=$1
    shift
    case $action in
        create)      __create_plugin "$@" ;;
        conf)        __conf_plugin "$@" ;;
        home)        __home_plugin "$@" ;;
        init)        __init_plugin "$@" ;;
        install)     __install_plugin "$@" ;;
        add-brew)    __add_brew "$@" ;;
        remove-brew) __remove_brew "$@" ;;
        -h|--help|"")
            cat <<'EOF'
用法: wzsh plugin <子命令> [参数]

子命令:
  create <name>              创建插件骨架
  conf <name>                编辑插件目录
  home <name>                输出插件目录路径
  init <name>                执行插件 init.zsh
  install [name] [--no-brew] 安装插件（无 name 则安装全部）
  add-brew <name> <formula>  将软件添加到插件 Brewfile
  remove-brew <name> <formula> 从插件 Brewfile 移除软件
  -h, --help                 显示帮助
EOF
            ;;
        *) zwarn "暂不支持 $action 指令" ;;
    esac
}

_usage() {
    cat <<'EOF'
用法: wzsh <命令> [参数]

命令:
  update          更新 wzsh
  conf            打开配置目录
  plugin          插件管理（wzsh plugin -h 查看子命令）
  -h, --help      显示帮助
EOF
}

# =============================================================================
# 入口
# =============================================================================

cmd="$1"
shift
case $cmd in
    -h|--help|"") _usage ;;
    *) "$cmd" "$@" ;;
esac
