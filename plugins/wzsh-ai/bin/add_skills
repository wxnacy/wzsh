#!/bin/zsh
# ## 脚本功能
#
# 将 `.agent/skills` 目录下的 `skill` 安装到指定 `agent` 项目级 `skill`
#
# ## 脚本需求：
#
# ### 默认变量
#
# - `AGENTS` 默认列表为 `codebuddy` `gemini-cli` `opencode`
# - `SKILL_DIR` 技能目录，`ls` 目录获取需要添加的技能。优先使用 `.agent/skills`，如果不存在使用 `skills`，如果还不存在，报错
#
# ### 参数说明
#
# - `-a` `--agent` 如果指定，则只安装到对应 `agent`。否则遍历 `AGENTS` 列表
# - `-g` 如果存在该参数，使用全局模式安装
#
# ### 功能细节
#
# - 自动检测技能目录，优先使用 `.agent/skills`，如果不存在使用 `skills`，如果都不存在则报错
# - 自动遍历技能目录下的所有技能目录
# - 对每个技能使用 `npx skills add` 命令安装到指定的 agent
# - 使用 `-y` 参数自动确认安装
# - 默认使用 `-p` 参数（项目模式），使用 `-g` 参数时则不使用 `-p`（全局模式）
#
# ## 调用示例
#
# ```bash
# # 安装所有技能到所有 agent
# ./add_skills
#
# # 只安装到 codebuddy agent
# ./add_skills -a codebuddy
#
# # 只安装到指定的多个 agent
# ./add_skills -a gemini-cli -a opencode
#
# # 使用全局模式安装
# ./add_skills -g
#
# # 指定 agent 并使用全局模式安装
# ./add_skills -a codebuddy -g
# ```

# 默认 agent 列表
AGENTS=("codebuddy" "gemini-cli" "opencode" "codex" "kiro-cli")
SINGLE_AGENT=""
GLOBAL_MODE=""

# 技能目录检测
SKILL_DIR=""
if [ -d ".agent/skills" ]; then
    SKILL_DIR=".agent/skills"
elif [ -d "skills" ]; then
    SKILL_DIR="skills"
else
    echo "错误: 未找到技能目录 (.agent/skills 或 skills)"
    exit 1
fi

echo "使用技能目录: $SKILL_DIR"

# 解析参数
while [[ $# -gt 0 ]]; do
    case $1 in
    -a | --agent)
        SINGLE_AGENT="$2"
        AGENTS=("$SINGLE_AGENT")
        shift 2
        ;;
    -g)
        GLOBAL_MODE="-g"
        shift
        ;;
    *)
        echo "未知参数: $1"
        echo "使用方法: $0 [-a|--agent <agent_name>] [-g]"
        exit 1
        ;;
    esac
done

# 遍历所有技能
for skill in $(ls $SKILL_DIR); do
    echo "处理技能: $skill"
    for agent in "${AGENTS[@]}"; do
        echo "  安装到: $agent"
        if [ -n "$GLOBAL_MODE" ]; then
            # 全局模式：不使用 -p
            npx skills add ./$SKILL_DIR/${skill} -a $agent -y $GLOBAL_MODE
        else
            # 项目模式：使用 -p
            npx skills add ./$SKILL_DIR/${skill} -a $agent -p -y
        fi
    done
done
