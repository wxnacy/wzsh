use_conda() {
    local env_name=$1
    # 指向你的 Homebrew 安装的 Miniconda 基础路径
    local conda_base="/opt/homebrew/Caskroom/miniconda/base"

    # 1. 加载 Conda 的初始化脚本（这是关键，让子 Shell 能识别 conda 命令）
    #    注意：这里直接 source conda.sh 是最稳妥的方式
    if [ -f "${conda_base}/etc/profile.d/conda.sh" ]; then
        source "${conda_base}/etc/profile.d/conda.sh"
    else
        log_error "Cannot find conda.sh at ${conda_base}/etc/profile.d/conda.sh"
        return 1
    fi

    # 2. 激活指定的环境
    conda activate "$env_name"
}

use_conda $@
