# 主题，通过 ghostty +list-themes 查看
theme = Catppuccin Frappe

# 字体族：按优先级排列，首选 JetBrains Mono，中文回退 Sarasa Mono SC
font-family = "JetBrains Mono, Sarasa Mono SC, Hack Nerd Font Mono, Apple Color Emoji"
# 字体大小（单位：pt）
font-size = 16
# 启用连字：让 !=、=>、<= 等符号显示得更自然
font-feature = calt
# 在 Retina 屏幕上轻微加粗字体，提升可读性
# font-thicken = true
# 行高增量，增加行间距减少阅读压力（百分比或像素）
adjust-cell-height = 10%
# 字符宽度微调（整数像素）
adjust-cell-width = 1

# 标题栏样式：native、transparent、tabs、hidden
macos-titlebar-style = tabs
# 背景不透明度：0.0（全透明）~ 1.0（不透明）
background-opacity = 0.86
# 背景模糊半径，配合透明度使用
background-blur-radius = 30
# 窗口状态记忆：关闭后记住窗口位置、标签页和分屏状态
window-save-state = always

# 快捷键：cmd+shift+, 重新加载配置
keybind = cmd+shift+comma=reload_config
# 全局快捷键：cmd+i 呼出/隐藏 quick-terminal
keybind = global:cmd+i=toggle_quick_terminal

# 滚动缓冲区行数上限，防止查看大量日志时内存无限增长
scrollback-limit = 10000
# 最小文本对比度（1.0 不限制，越大对比越强），防止 TUI 应用中文字难以辨认
minimum-contrast = 1.3


# quick-terminal 下拉终端配置
# quick-terminal-position：下拉方向，可选 top、bottom、left、right、center
quick-terminal-position = top
# quick-terminal-screen：显示在哪个屏幕，可选 main、mouse、macos-menu-bar
quick-terminal-screen = macos-menu-bar
# quick-terminal-autohide：失去焦点时自动隐藏
quick-terminal-autohide = true
# quick-terminal 高度占屏幕比例
quick-terminal-size = 1440px, 900px
